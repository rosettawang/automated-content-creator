# macOS
.DS_Store
# Office lock files
.~lock.*#
# Temporary video working area (pulled clips are disposable)
_video_temp/
# Local footage library (MEDIA_DIR) — imported/pulled clips, large & disposable
media/
# Rendered / source media — large binaries, keep edit specs not the video
clips_out/*.mp4
clips_out/*.mov
clips_out/*.mkv
# Keep: clips_out/*.fcpxml, clips_out/*.txt (edit decisions & notes)
# Reusable encoded export segments (B4 cache) — large binaries, regenerable.
segment_cache/
# Editor app database — written live by the running app. NOT tracked: a git
# checkout/switch would otherwise revert (and has wiped) the user's real library.
# Recover the catalog from content_intake_log.xlsx (migrate_xlsx.py); keep local
# editor.db.bak-* backups for timelines/edits.
editor/data/editor.db
__pycache__/
*.pyc
# pywebview auto-creates this on macOS for its pyobjc/Cocoa backend when the
# system Python lacks pyobjc -- a generated runtime artifact, not source.
editor/venv/
# API keys (Composio, Anthropic, etc.) -- never commit secrets
editor/.env
# Generated caches (regenerable from source media) -- not source
editor/data/thumbs/
editor/data/faces/
editor/data/proxies/
editor/data/ref_audio/
# Python build artifact
editor/content_creator.egg-info/
# Per-user local Claude Code settings (permissions etc.); keep launch.json shared
.claude/settings.local.json
# local DB safety backups
editor/data/*.bak-*
editor/data/*.bak
# SQLite WAL sidecars (WAL mode) — regenerated, never source
editor/data/*.db-wal
editor/data/*.db-shm
# macOS/pywebview FUSE artifacts
editor/data/.fuse_hidden*
