# macOS
.DS_Store
# Office lock files
.~lock.*#
# Temporary video working area (pulled clips are disposable)
_video_temp/
# Rendered / source media — large binaries, keep edit specs not the video
clips_out/*.mp4
clips_out/*.mov
clips_out/*.mkv
# Keep: clips_out/*.fcpxml, clips_out/*.txt (edit decisions & notes)
# Editor app: clips.db holds real project/timeline work (not just regenerable
# clip metadata), so it's committed rather than ignored — only ignore caches.
__pycache__/
*.pyc
# pywebview auto-creates this on macOS for its pyobjc/Cocoa backend when the
# system Python lacks pyobjc -- a generated runtime artifact, not source.
editor/venv/
